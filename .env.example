# Throughline — copy to .env.local (Next.js) and/or .env (docker compose).
# The ONE switch the whole architecture pivots on:
COGNEE_TARGET=local            # local | cloud | mock

# Single dataset everywhere (day-3: one-dataset tenant neutralizes #3520).
COGNEE_DATASET=throughline_demo

# ── local (self-hosted via docker compose) ──────────────────────────────────
COGNEE_LOCAL_URL=http://localhost:8000/api/v1
COGNEE_LOCAL_USER=default@throughline.dev
COGNEE_LOCAL_PASSWORD=throughline-dev

# ── cloud (Cognee Cloud / cogwit — opens Wed Jul 1) ─────────────────────────
COGNEE_CLOUD_URL=https://api.cognee.ai/api/v1
COGNEE_API_KEY=                 # mint at platform.cognee.ai after redeeming COGNEE-35

# ── LLM for the local docker engine (NOT read by the Next.js app) ───────────
# Use a PAID key — the OpenAI free tier fails Cognee's rate limits (day-3 note).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
